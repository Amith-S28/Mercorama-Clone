# ─── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook secret — generate with: stripe listen --print-secret
# or copy from Stripe Dashboard → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Runtime (set automatically by deploy.sh / ecosystem.config.js) ───────────
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
